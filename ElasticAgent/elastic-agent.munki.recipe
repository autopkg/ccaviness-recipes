<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
	<dict>
		<key>Description</key>
		<string>Uploads an elastic-agent pkg to munki.

Use the ELASTIC_URL and ELASTIC_ENROLLMENT_TOKEN input values to configure the elastic-agent enrollment settings.
Uses ELASTIC_VERSION from elastic-agent.download recipe to determine the version of the pkg.
</string>
		<key>Identifier</key>
		<string>com.github.ccaviness.munki.elastic-agent</string>
		<key>Input</key>
		<dict>
			<key>MUNKI_CATEGORY</key>
			<string>Security</string>
			<key>MUNKI_REPO_SUBDIR</key>
			<string>apps/elastic-agent</string>
			<key>DERIVE_MIN_OS</key>
			<string>YES</string>
			<key>pkginfo</key>
			<dict>
				<key>catalogs</key>
				<array>
					<string>testing</string>
				</array>
				<key>category</key>
				<string>%MUNKI_CATEGORY%</string>
				<key>description</key>
				<string>Elastic Agent is a single, unified way to add monitoring for logs, metrics, and other types of data to a host.</string>
				<key>developer</key>
				<string>Elasticsearch, Inc</string>
				<key>display_name</key>
				<string>Elastic Agent</string>
				<key>name</key>
				<string>%NAME%</string>
				<key>unattended_install</key>
				<true/>
				<key>unattended_uninstall</key>
				<true/>
				<key>uninstall_method</key>
				<string>uninstall_script</string>
				<key>uninstall_script</key>
				<string><![CDATA[#!/bin/bash
if [[ -x /Library/Elastic/Agent/elastic-agent ]]; then
    if ! /Library/Elastic/Agent/elastic-agent uninstall --force; then
        launchctl bootout system/co.elastic.agent || true
        rm -rf /Library/Elastic/Agent
    fi
fi
exit 0
]]></string>
			</dict>
		</dict>
		<key>MinimumVersion</key>
		<string>2.7</string>
		<key>ParentRecipe</key>
		<string>com.github.ccaviness.pkg.elastic-agent</string>
		<key>Process</key>
		<array>
			<dict>
				<key>Arguments</key>
				<dict>
					<key>additional_pkginfo</key>
					<dict>
						<key>version</key>
						<string>%ELASTIC_VERSION%</string>
						<key>installcheck_script</key>
						<string><![CDATA[#!/bin/bash

set -eu

INSTALLED=1
NOT_INSTALLED=0
ELASTIC_AGENT="/Library/Elastic/Agent/elastic-agent"
ELASTIC_AGENT_VERSION_STRING=$("${ELASTIC_AGENT}" version || echo "Binary: 0.0")
ELASTIC_AGENT_VERSION=$(awk '$1 == "Binary:" { print $2 }' <<< "${ELASTIC_AGENT_VERSION_STRING}")
ELASTIC_AGENT_VERSION="${ELASTIC_AGENT_VERSION:-0.0}"
OFFERED_VERSION="%ELASTIC_VERSION%"

echo "Elastic Agent version: ${ELASTIC_AGENT_VERSION}"
echo "Offered version: ${OFFERED_VERSION}"

function version_gte() {
    # shellcheck disable=SC2312
    [[ "$1" == "$2" || "$(printf '%s\n' "$@" | sort -V | head -n 1)" != "$1" ]]
}

# Non-zero exit codes indicate that the item in question is installed
# shellcheck disable=SC2310
if version_gte "${ELASTIC_AGENT_VERSION}" "${OFFERED_VERSION}"; then
    echo "Elastic Agent version is up-to-date"
    exit "${INSTALLED}"
else
    echo "Elastic Agent version is not up-to-date"
    exit "${NOT_INSTALLED}"
fi
]]></string>
					</dict>
				</dict>
				<key>Processor</key>
				<string>MunkiPkginfoMerger</string>
			</dict>
			<dict>
				<key>Arguments</key>
				<dict>
					<key>pkg_path</key>
					<string>%pkg_path%</string>
					<key>repo_subdirectory</key>
					<string>%MUNKI_REPO_SUBDIR%</string>
				</dict>
				<key>Processor</key>
				<string>MunkiImporter</string>
			</dict>
		</array>
	</dict>
</plist>
