<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
	<dict>
		<key>Description</key>
		<string>Downloads the latest Claude Desktop, creates a non-relocatable package, and imports into Munki.</string>
		<key>Identifier</key>
		<string>com.github.ccaviness.munki.ClaudeDesktop</string>
		<key>Input</key>
		<dict>
			<key>NAME</key>
			<string>ClaudeDesktop</string>
			<key>MUNKI_CATEGORY</key>
			<string>Utilities</string>
			<key>MUNKI_REPO_SUBDIR</key>
			<string>apps/%NAME%</string>
			<key>pkginfo</key>
			<dict>
				<key>catalogs</key>
				<array>
					<string>testing</string>
				</array>
				<key>category</key>
				<string>%MUNKI_CATEGORY%</string>
				<key>description</key>
				<string>Claude Desktop by Anthropic.</string>
				<key>developer</key>
				<string>Anthropic PBC</string>
				<key>display_name</key>
				<string>Claude Desktop</string>
				<key>name</key>
				<string>%NAME%</string>
				<key>unattended_install</key>
				<true/>
				<key>unattended_uninstall</key>
				<true/>
				<key>uninstall_method</key>
				<string>uninstall_script</string>
				<key>uninstall_script</key>
				<string><![CDATA[#!/bin/bash
/usr/bin/killall "Claude" 2>/dev/null
/bin/rm -rf "/Applications/Claude.app"
/usr/sbin/pkgutil --forget com.anthropic.claudefordesktop
exit 0
]]></string>
			</dict>
		</dict>
		<key>MinimumVersion</key>
		<string>2.3</string>
		<key>ParentRecipe</key>
		<string>com.github.ccaviness.pkg.ClaudeDesktop</string>
		<key>Process</key>
		<array>
			<dict>
				<key>Processor</key>
				<string>MunkiImporter</string>
				<key>Arguments</key>
				<dict>
					<key>pkg_path</key>
					<string>%pkg_path%</string>
					<key>repo_subdirectory</key>
					<string>%MUNKI_REPO_SUBDIR%</string>
				</dict>
			</dict>
		</array>
	</dict>
</plist>
